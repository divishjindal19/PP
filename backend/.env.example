# AI University Recommender - Environment Variables
# Copy this to .env and fill in your values

# Google OAuth (optional - app works in demo mode without it)
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Groq API for RAG chatbot (optional - falls back to rule-based)
GROQ_API_KEY=GROQ_API_KEY_HERE

# Database
DATABASE_URL=sqlite:///./university_recommender.db

# Frontend URL
FRONTEND_URL=http://localhost:5173
